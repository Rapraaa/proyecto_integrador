        {
          "name": "GET /interviews (historial)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{base_url}}/interviews", "host": ["{{base_url}}"], "path": ["interviews"] }
          }
        },
        {
          "name": "GET /interviews/:id (detalle)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{base_url}}/interviews/{{interview_id}}", "host": ["{{base_url}}"], "path": ["interviews", "{{interview_id}}"] }
          }
        }
      ]
